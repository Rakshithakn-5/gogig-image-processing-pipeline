generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Image {
  id            String   @id @default(uuid())
  filename      String
  originalName  String
  path          String
  mimeType      String
  size          Int

  status        String   @default("pending")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  analysis      Analysis?
}


model Analysis {
  id          String   @id @default(uuid())

  imageId     String   @unique
  image       Image    @relation(fields: [imageId], references: [id])

  blurry      Boolean
  lowLight    Boolean
  duplicate   Boolean
  ocrText     String?

  confidence Float

  createdAt   DateTime @default(now())
}